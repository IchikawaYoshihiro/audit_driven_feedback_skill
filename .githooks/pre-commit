#!/usr/bin/env sh
# Pre-commit guardrail: validate every SKILL.md before the commit lands.
# Enable once per clone:  git config core.hooksPath .githooks
#
# Runs the same check as CI (tools/lint_skill.py). Bypass in a pinch with
# `git commit --no-verify`.

root="$(git rev-parse --show-toplevel)" || exit 1
cd "$root" || exit 1

if command -v python3 >/dev/null 2>&1; then
  PY=python3
elif command -v python >/dev/null 2>&1; then
  PY=python
else
  echo "pre-commit: python not found; skipping skill lint" >&2
  exit 0
fi

# Ensure the linter's only dependency is present (no-op if already installed).
"$PY" -c "import yaml" >/dev/null 2>&1 || "$PY" -m pip install --quiet pyyaml

if ! "$PY" tools/lint_skill.py; then
  echo "" >&2
  echo "pre-commit: skill lint failed. Fix the issues above, or bypass with 'git commit --no-verify'." >&2
  exit 1
fi
